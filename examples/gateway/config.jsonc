{
  // Provider credentials and base URLs.
  // API keys support ${ENV_VAR} syntax for environment variable substitution.
  "providers": {
    "openai_chat": {
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "https://api.openai.com/v1"
    },
    "openai_responses": {
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "https://api.openai.com/v1"
    },
    "anthropic": {
      "api_key": "${ANTHROPIC_API_KEY}",
      "base_url": "https://api.anthropic.com"
    },
    "google": {
      "api_key": "${GOOGLE_API_KEY}",
      "base_url": "https://generativelanguage.googleapis.com"
    }
  },

  // User-created tool profiles are stored here. The immutable "builtin"
  // profile is bundled with the gateway and is not duplicated in this file.
  "tool_profiles": {},

  // Model groups are the only routing definitions. Group type controls
  // LLM vs embedding behavior; LLM models may declare text/vision only.
  "model_groups": {
    "OpenAI Chat": {
      "provider": "openai_chat",
      "type": "llm",
      "tool_profile": "builtin",
      "models": {
        "gpt-4o": {"capabilities": ["text", "vision"]},
        "gpt-4o-mini": {"capabilities": ["text", "vision"]},
        "gpt-4.1": {"capabilities": ["text", "vision"]},
        "gpt-4.1-mini": {"capabilities": ["text", "vision"]},
        "gpt-4.1-nano": {"capabilities": ["text"]}
      }
    },
    "Anthropic": {
      "provider": "anthropic",
      "type": "llm",
      "tool_profile": "builtin",
      "models": {
        "claude-sonnet-4-20250514": {"capabilities": ["text", "vision"]},
        "claude-3-5-haiku-20241022": {"capabilities": ["text", "vision"]}
      }
    },
    "Google": {
      "provider": "google",
      "type": "llm",
      "tool_profile": "builtin",
      "models": {
        "gemini-2.0-flash": {"capabilities": ["text", "vision"]},
        "gemini-2.5-pro": {"capabilities": ["text", "vision"]},
        "gemini-2.5-flash": {"capabilities": ["text", "vision"]}
      }
    }
  },

  // Server settings
  "server": {
    // Keep loopback for local use. Docker overrides this to 0.0.0.0 and must
    // retain the mandatory password and access key below.
    "host": "127.0.0.1",
    "port": 8765,
    // One of 64, 128, 256, 512, 1024, or "unlimited". Values are MiB.
    "request_body_limit_mb": 128,
    "admin_password": "${CODEX_ROSETTA_ADMIN_PASSWORD}",
    "credential_visible": false,
    "api_keys": [
      {
        "id": "default",
        "label": "Default client",
        "key": "${CODEX_ROSETTA_API_KEY}"
      }
    ]
  }
}
