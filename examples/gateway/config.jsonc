{
  // Provider credentials and base URLs.
  // API keys support ${ENV_VAR} syntax for environment variable substitution.
  "providers": {
    "openai_chat": {
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "https://api.openai.com/v1"
    },
    "openai_responses": {
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "https://api.openai.com/v1",
      "provider": "openai",
      "api_type": "responses_passthrough"
    },
    "anthropic": {
      "api_key": "${ANTHROPIC_API_KEY}",
      "base_url": "https://api.anthropic.com"
    },
    "google": {
      "api_key": "${GOOGLE_API_KEY}",
      "base_url": "https://generativelanguage.googleapis.com"
    }
  },

  // User-created tool profiles are stored here. The immutable "builtin"
  // profile is bundled with the gateway and is not duplicated in this file.
  "tool_profiles": {},

  // Model groups are the only routing definitions. Gateway-side modality
  // filtering is supplied by exact matches in the bundled model presets.
  "model_groups": {
    "OpenAI Chat": {
      "provider": "openai_chat",
      "type": "llm",
      "tool_profile": "builtin",
      "models": {
        "gpt-4o": {},
        "gpt-4o-mini": {},
        "gpt-4.1": {},
        "gpt-4.1-mini": {},
        "gpt-4.1-nano": {}
      }
    },
    "Anthropic": {
      "provider": "anthropic",
      "type": "llm",
      "tool_profile": "builtin",
      "models": {
        "claude-sonnet-4-20250514": {},
        "claude-3-5-haiku-20241022": {}
      }
    },
    "Google": {
      "provider": "google",
      "type": "llm",
      "tool_profile": "builtin",
      "models": {
        "gemini-2.0-flash": {},
        "gemini-2.5-pro": {},
        "gemini-2.5-flash": {}
      }
    }
  },

  // Server settings
  "server": {
    // Keep loopback for local use. Docker overrides this to 0.0.0.0 and must
    // retain the mandatory password and access key below.
    "host": "127.0.0.1",
    "port": 8765,
    // One of 64, 128, 256, 512, 1024, or "unlimited". Values are MiB.
    "request_body_limit_mb": 128,
    // Optional browser/PDF sidecar. Docker's compose-up-web-run target supplies
    // equivalent environment overrides, so this block can stay commented there.
    // "web_run": {
    //   "base_url": "http://web-run:8080",
    //   "token": "${CODEX_ROSETTA_WEB_RUN_TOKEN}",
    //   "timeout_seconds": 45
    // },
    "admin_password": "${CODEX_ROSETTA_ADMIN_PASSWORD}",
    "credential_visible": false,
    "api_keys": [
      {
        "id": "default",
        "label": "Default client",
        "key": "${CODEX_ROSETTA_API_KEY}"
      }
    ]
  }
}
