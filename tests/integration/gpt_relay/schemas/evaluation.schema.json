{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GPT relay compatibility result",
  "type": "object",
  "required": [
    "suite",
    "scenario",
    "representative_provider",
    "model",
    "openai_identity",
    "synthetic_codex_backend_auth",
    "actual_upstream_models",
    "classification"
  ],
  "properties": {
    "suite": {"const": "gpt_relay_compatibility"},
    "scenario": {"enum": ["C0", "C1", "C2", "C3", "C4", "C5"]},
    "representative_provider": {"type": "string", "minLength": 1},
    "model": {"type": "string", "minLength": 1},
    "openai_identity": {"type": "boolean"},
    "synthetic_codex_backend_auth": {"type": "boolean"},
    "actual_upstream_models": {"type": "array", "items": {"type": "string"}},
    "classification": {"enum": ["success", "success_with_deviation", "failure"]},
    "error": {"type": ["string", "null"]}
  },
  "additionalProperties": true
}
